FROM golang:1.24-alpine AS builder
WORKDIR /app
COPY apps/generator/go.mod apps/generator/go.sum ./
RUN go mod download
COPY apps/generator/ .
RUN go build -o /api ./cmd/api

FROM alpine:latest
RUN apk --no-cache add ca-certificates
COPY --from=builder /api /api
ENV PORT=8080
EXPOSE 8080
ENTRYPOINT ["/api"]
