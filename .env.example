# Database
DATABASE_URL="postgresql://postgres:password@localhost:5433/infraup"

# Resend (email)
RESEND_API_KEY=""

# GitHub API (for sync CLI — 5000 req/hour authenticated)
GITHUB_TOKEN=""

# Phase 2 feature flag — flip to "true" when generator is live
NEXT_PUBLIC_GENERATOR_LIVE="false"

# Auth (Phase 2 — set now, unused until then)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://infraup.dev"

# Go API base URL (for waitlist form submissions)
NEXT_PUBLIC_API_URL="http://localhost:8080"

# Trust reverse-proxy forwarding headers in the Go API
TRUST_PROXY_HEADERS="false"

# ------------------------------------------------------------------------------
# Production (e.g. Dokploy) — set at runtime per service
# ------------------------------------------------------------------------------
# web:  DATABASE_URL (if build needs it), NEXT_PUBLIC_* baked at build or via env
# api:  DATABASE_URL (required), RESEND_API_KEY (optional, waitlist emails), PORT (default 8080), TRUST_PROXY_HEADERS (default false)
# sync: DATABASE_URL (required), GITHUB_TOKEN (recommended)
# ------------------------------------------------------------------------------
# DATABASE_URL          (required for api/sync) postgresql://user:SECRET@host:5432/infraup
# GITHUB_TOKEN          (recommended, sync)     ghp_xxxx — PAT with repo read
# RESEND_API_KEY        (optional, api)         re_xxxx — waitlist emails
# NEXT_PUBLIC_API_URL   (optional, web)         https://api.infraup.dev — backend for frontend
# NEXT_PUBLIC_GENERATOR_LIVE (optional)        true | false
# TRUST_PROXY_HEADERS   (optional, api)         true | false
# NEXTAUTH_SECRET       (Phase 2)               openssl rand -base64 32
# NEXTAUTH_URL          (Phase 2)               https://infraup.dev
