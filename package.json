    "db:migrate": "pnpm --filter @infraup/db db:migrate"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "turbo": "^2.8.16"
  }
}
